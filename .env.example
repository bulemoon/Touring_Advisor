# 知乎直接回答
# 注册 developer.zhihu.com -> 应用管理 -> Access Secret
ZHIHU_ACCESS_SECRET=

# 和风天气
# 注册 dev.qweather.com -> 控制台 -> 应用管理 -> 获取 Key（Web API）
QWEATHER_API_KEY=

# DeepSeek
# 注册 platform.deepseek.com -> API Keys -> 获取 API Key
DEEPSEEK_API_KEY=

# 高德地图 Web 服务 API（POI 搜索等）
# 注册 lbs.amap.com -> 控制台 -> 应用管理 -> 获取 Key -> 选择「Web 服务」类型
AMAP_SERVER_KEY=

# Redis 连接地址
# Railway 部署时会自动注入 REDIS_URL 环境变量，本地开发用 localhost
REDIS_URL=redis://localhost:6379
